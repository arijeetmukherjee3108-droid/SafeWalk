<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Pressed state: white border -->
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#1C1C28" />
            <stroke
                android:width="1.5dp"
                android:color="#BBFFFFFF" />
            <corners android:radius="16dp" />
        </shape>
    </item>

    <!-- Default state: visible subtle border -->
    <item>
        <shape>
            <solid android:color="@color/panel" />
            <stroke
                android:width="1dp"
                android:color="#30FFFFFF" />
            <corners android:radius="16dp" />
        </shape>
    </item>

</selector>
