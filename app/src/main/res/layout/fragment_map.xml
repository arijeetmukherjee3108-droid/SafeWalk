<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.map.MapFragment">

    <!-- Map Canvas -->
    <org.osmdroid.views.MapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Search Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="10dp"
        android:background="@drawable/bg_panel_rounded"
        android:backgroundTint="@color/surface"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="10dp"
        android:paddingVertical="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔍"
            android:textSize="25sp" />

        <EditText
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:background="@null"
            android:hint="Where to? Search a destination…"
            android:textColor="@color/text"
            android:textColorHint="@color/sub"
            android:textSize="17sp" />
    </LinearLayout>

    <!-- Selection Overlay (Visible only in Pick Mode) -->
    <LinearLayout
        android:id="@+id/selectionLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_panel_rounded"
        android:backgroundTint="@color/surface"
        android:elevation="8dp"
        android:orientation="vertical"
        android:padding="16dp"
        android:visibility="gone"
        tools:visibility="visible">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Incident Location"
            android:textColor="@color/text"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/selectedLocationText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Tap on the map to select a point"
            android:textColor="@color/sub"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnConfirmLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:backgroundTint="@color/safe"
            android:text="Confirm Location"
            android:textAllCaps="false"
            android:textColor="@color/white"
            app:cornerRadius="12dp" />
    </LinearLayout>

    <!-- Route Legend -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginHorizontal="8dp"
        android:layout_marginBottom="10dp"
        android:background="@drawable/bg_panel_rounded"
        android:backgroundTint="@color/surface"
        android:elevation="4dp"
        android:orientation="horizontal"
        android:paddingHorizontal="10dp"
        android:paddingVertical="8dp">

        <LinearLayout
            style="@style/LegendItem"
            android:layout_width="0dp"
            android:layout_weight="1">
            <View style="@style/LegendDot" android:backgroundTint="@color/safe" />
            <TextView style="@style/LegendLabel" android:text="Safest" />
        </LinearLayout>

        <LinearLayout
            style="@style/LegendItem"
            android:layout_width="0dp"
            android:layout_weight="1">
            <View style="@style/LegendDot" android:backgroundTint="@color/amber" />
            <TextView style="@style/LegendLabel" android:text="Fastest" />
        </LinearLayout>

        <LinearLayout
            style="@style/LegendItem"
            android:layout_width="0dp"
            android:layout_weight="1">
            <View style="@style/LegendDot" android:backgroundTint="@color/ember" />
            <TextView style="@style/LegendLabel" android:text="Shortest" />
        </LinearLayout>

        <LinearLayout
            style="@style/LegendItem"
            android:layout_width="0dp"
            android:layout_weight="1">
            <View style="@style/LegendDot" android:backgroundTint="@color/pulse" />
            <TextView style="@style/LegendLabel" android:text="Heatmap" />
        </LinearLayout>

    </LinearLayout>

</FrameLayout>