<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="49dp">

        <!-- HEADER -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="20dp"
            android:paddingBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Incident Reports"
                android:textColor="@color/text"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="@drawable/bg_blockchain_badge"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="Community"
                android:textColor="@color/ember"
                android:textSize="10sp" />
        </RelativeLayout>

        <!-- TABS: All Reports / My Reports -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/reportTabs"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@drawable/bg_panel_rounded_14"
            app:tabBackground="@android:color/transparent"
            app:tabGravity="fill"
            app:tabMaxWidth="0dp"
            app:tabMode="fixed"
            app:tabIndicatorHeight="0dp"
            app:tabSelectedTextColor="@color/text"
            app:tabTextColor="@color/sub"
            app:tabTextAppearance="@style/TabText"
            app:tabRippleColor="@android:color/transparent">

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="All Reports" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="My Reports" />
        </com.google.android.material.tabs.TabLayout>

        <!-- CATEGORY FILTER CHIPS -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="12dp"
            android:scrollbars="none"
            android:overScrollMode="never"
            android:clipToPadding="false">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/filterChipGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:selectionRequired="true"
                app:chipSpacingHorizontal="8dp">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipAll"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="All"
                    android:textColor="@color/text"
                    app:chipBackgroundColor="@color/panel"
                    app:chipStrokeColor="@color/border"
                    app:chipStrokeWidth="1dp"
                    app:chipCornerRadius="20dp"
                    app:checkedIconVisible="false"
                    app:chipMinHeight="36dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipHarassment"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Harassment"
                    android:textColor="@color/text"
                    app:chipBackgroundColor="@color/panel"
                    app:chipStrokeColor="@color/border"
                    app:chipStrokeWidth="1dp"
                    app:chipCornerRadius="20dp"
                    app:checkedIconVisible="false"
                    app:chipMinHeight="36dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipStalking"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Stalking"
                    android:textColor="@color/text"
                    app:chipBackgroundColor="@color/panel"
                    app:chipStrokeColor="@color/border"
                    app:chipStrokeWidth="1dp"
                    app:chipCornerRadius="20dp"
                    app:checkedIconVisible="false"
                    app:chipMinHeight="36dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipSuspicious"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Suspicious"
                    android:textColor="@color/text"
                    app:chipBackgroundColor="@color/panel"
                    app:chipStrokeColor="@color/border"
                    app:chipStrokeWidth="1dp"
                    app:chipCornerRadius="20dp"
                    app:checkedIconVisible="false"
                    app:chipMinHeight="36dp" />

            </com.google.android.material.chip.ChipGroup>
        </HorizontalScrollView>

    </LinearLayout>

    <!-- REPORTS LIST -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/reportsRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingTop="4dp"
        android:paddingBottom="16dp" />

</LinearLayout>
