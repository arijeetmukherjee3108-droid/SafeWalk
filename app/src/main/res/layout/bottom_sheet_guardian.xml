<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Guardian Alert"
        android:textColor="@color/text"
        android:textSize="14sp"
        android:textStyle="bold" />

    <FrameLayout
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="center"
        android:layout_marginVertical="16dp"
        android:background="@drawable/bg_brand_icon">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="SOS"
            android:textColor="@color/white"
            android:textStyle="bold"
            android:textSize="14sp" />
    </FrameLayout>

    <TextView
        android:id="@+id/alertContactName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="Riya Sharma triggered SOS!"
        android:textColor="@color/ember"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/lastSeenLocation"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="4dp"
        android:text="Last seen: Hauz Khas • 2 min ago"
        android:textColor="@color/sub"
        android:textSize="10sp" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="12dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <View
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:background="@drawable/bg_status_dot_red" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="Real-time location updating…"
            android:textColor="@color/sub"
            android:textSize="10sp" />
    </LinearLayout>

    <Button
        android:id="@+id/callNowButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:backgroundTint="@color/ember"
        android:text="Call Now"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textStyle="bold"
        app:cornerRadius="10dp" />

    <Button
        android:id="@+id/trackLiveButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:backgroundTint="@color/panel"
        android:text="Track Live"
        android:textAllCaps="false"
        android:textColor="@color/ember"
        app:cornerRadius="10dp"
        app:strokeColor="@color/ember"
        app:strokeWidth="1dp" />

    <Button
        android:id="@+id/dismissButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:backgroundTint="@color/panel"
        android:text="Dismiss"
        android:textAllCaps="false"
        android:textColor="@color/sub"
        app:cornerRadius="10dp" />

</LinearLayout>