<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="40dp"
        android:paddingBottom="24dp">

        <!-- HEADER -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Report Incident"
                android:textColor="@color/text"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:background="@drawable/bg_blockchain_badge"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="Blockchain secured"
                android:textColor="@color/ember"
                android:textSize="10sp" />
        </RelativeLayout>

        <!-- CATEGORY -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Category"
            android:textColor="@color/sub"
            android:textSize="12sp"
            android:layout_marginBottom="8dp" />

        <GridLayout
            android:id="@+id/categoryGrid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="3"
            android:rowOrderPreserved="false">

            <TextView style="@style/ReportChip" android:layout_columnWeight="1" android:layout_width="0dp" android:text="Harassment"/>
            <TextView style="@style/ReportChip" android:layout_columnWeight="1" android:layout_width="0dp" android:text="Assault"/>
            <TextView style="@style/ReportChip" android:layout_columnWeight="1" android:layout_width="0dp" android:text="Lighting"/>
            <TextView style="@style/ReportChip" android:layout_columnWeight="1" android:layout_width="0dp" android:text="Traffic"/>
            <TextView style="@style/ReportChip" android:layout_columnWeight="1" android:layout_width="0dp" android:text="Crowd"/>
            <TextView style="@style/ReportChip" android:layout_columnWeight="1" android:layout_width="0dp" android:text="Other"/>
        </GridLayout>

        <!-- DESCRIPTION -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Description"
            android:textColor="@color/sub"
            android:textSize="12sp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/descriptionInput"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="@drawable/bg_panel_rounded"
            android:gravity="top"
            android:hint="Tell us what happened..."
            android:padding="14dp"
            android:textColor="@color/text"
            android:textColorHint="@color/sub"
            android:textSize="14sp" />

        <!-- EVIDENCE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Evidence"
            android:textColor="@color/sub"
            android:textSize="12sp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp" />

        <FrameLayout
            android:id="@+id/evidenceUpload"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:background="@drawable/bg_dashed_border">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="Tap to upload photo"
                android:textColor="@color/sub"
                android:textSize="13sp" />
        </FrameLayout>

        <!-- LOCATION -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_safe_glow_rounded"
            android:padding="12dp">

            <TextView
                android:id="@+id/locationText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Detecting your location..."
                android:textColor="@color/safe"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- SUBMIT BUTTON -->
        <Button
            android:id="@+id/submitButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="28dp"
            android:backgroundTint="@color/ember"
            android:text="Submit Report →"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:elevation="6dp"
            app:cornerRadius="14dp" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>